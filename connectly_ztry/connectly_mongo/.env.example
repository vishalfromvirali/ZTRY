# ── REQUIRED ────────────────────────────────────────────────────────────────
SECRET_KEY=your-random-secret-key-here-change-this

# MongoDB Atlas URI (free tier: https://mongodb.com/atlas)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ztry?retryWrites=true&w=majority

# ── AI KEYS (pick one — both are FREE) ──────────────────────────────────────

# Groq API — Free Llama 3 AI (https://console.groq.com)
# Fast, reliable, free tier
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

